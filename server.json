{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.plural-pinelabs/pinelabs-online-mcp",
  "title": "PineLabs Plural PG — Payment Gateway MCP Server",
  "description": "Create payment orders, checkout, subscriptions & UPI via PineLabs Plural PG gateway",
  "version": "0.1.0",
  "websiteUrl": "https://developer.pinelabsonline.com",
  "repository": {
    "url": "https://github.com/plural-pinelabs/pinelabs-online-mcp",
    "source": "github",
    "id": "1212551094"
  },
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "canonical_owner": "pinelabs",
"aliases": [
    "pinelabs",
    "pine labs",
    "pinelabs online",
    "pine labs online",
    "pinelabs-online",

    "plural",
    "plural online",
    "pluralonline",
    "pinelabs plural",

    "pg",
    "pl",
    "pl pg",

    "payment gateway",
    "online payment gateway",
    "checkout gateway",

    "pg checkout",
    "payment checkout",
    "online checkout",

    "payments api",
    "payment api",
    "pg api",
    "checkout api",

    "payment integration",
    "gateway integration",

    "pine",
    "pinelabs pg"
  ],
     "keywords": [
    "payments",
    "online payments",
    "payment processing",
    "digital payments",
    "accept payments",

    "checkout",
    "online checkout",
    "payment checkout",
    "hosted checkout",
    "payment page",

    "gateway",
    "payment gateway",
    "payment-gateway",
    "online gateway",

    "upi",
    "cards",
    "credit card",
    "debit card",
    "netbanking",
    "wallet",
    "emi",
    "cardless emi",

    "subscriptions",
    "recurring payments",
    "orders",
    "order payments",
    "collect payments",

    "payments api",
    "payment api",
    "checkout api",
    "gateway api",
    "payment integration",
    "sdk",

    "create payment",
    "initiate payment",
    "process payment"
  ],
      "domain": "payments",
      "status": "active",
      "priority": 10
    }
  },
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.pinelabs.com/mcp",
      "headers": [
        {
          "name": "X-Client-Id",
          "description": "Pine Labs Client ID from your merchant dashboard",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "X-Client-Secret",
          "description": "Pine Labs Client Secret from your merchant dashboard",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "pinelabs-mcp-server",
      "version": "0.1.0",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "stdio",
          "description": "Run in stdio transport mode"
        }
      ],
      "environmentVariables": [
        {
          "name": "PINELABS_CLIENT_ID",
          "description": "Pine Labs Client ID from your merchant dashboard",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "PINELABS_CLIENT_SECRET",
          "description": "Pine Labs Client Secret from your merchant dashboard",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "PINELABS_ENV",
          "description": "Target environment for API calls",
          "isRequired": false,
          "default": "uat",
          "choices": ["uat", "prod"]
        }
      ]
    },
    {
      "registryType": "oci",
      "identifier": "docker.io/pinelabs/mcp-server:0.1.0",
      "runtimeHint": "docker",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "named",
          "name": "-i"
        }
      ],
      "environmentVariables": [
        {
          "name": "PINELABS_CLIENT_ID",
          "description": "Pine Labs Client ID from your merchant dashboard",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "PINELABS_CLIENT_SECRET",
          "description": "Pine Labs Client Secret from your merchant dashboard",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "PINELABS_ENV",
          "description": "Target environment for API calls",
          "isRequired": false,
          "default": "uat",
          "choices": ["uat", "prod"]
        }
      ]
    }
  ]
}
