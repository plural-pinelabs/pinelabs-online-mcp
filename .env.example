# Pine Labs MCP Server — Environment Variables
# Copy this file to .env and fill in your credentials

PINELABS_CLIENT_ID=your-client-id-here
PINELABS_CLIENT_SECRET=your-client-secret-here
PINELABS_ENV=uat
PINELABS_BASE_URL=https://api.pluralpay.in/api
PINELABS_TOKEN_URL=https://api.pluralpay.in/api/auth/v1/token
PINELABS_DOCS_BASE_URL=https://developer.pinelabsonline.com
PINELABS_ALLOWED_IMAGE_DOMAINS=pinepg.in,pluralpay.in,amazonaws.com,s3.ap-south-1.amazonaws.com
HTTP_TIMEOUT=30.0
LOG_LEVEL=INFO
